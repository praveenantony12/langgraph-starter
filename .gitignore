# ── Secrets — NEVER commit these ──────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo

# ── Virtual environment ────────────────────────────────────────────────────────
.venv/
venv/
env/

# ── uv ────────────────────────────────────────────────────────────────────────
# uv.lock is intentionally NOT listed here.
# Lock files should be committed so deployments are reproducible.

# ── Test output ────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ── Tool caches ────────────────────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/

# ── OS noise ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
